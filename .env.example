# Supabase — get these from your Supabase project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# Keep false until both OAuth providers are enabled and tested in Supabase.
NEXT_PUBLIC_OAUTH_LOGIN_ENABLED=false
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Transactional email — required for message, document, invoice, and change-order alerts.
RESEND_API_KEY=re_your-key-here
NOTIFICATION_FROM_EMAIL=James Roman Advisory <notifications@jamesroman.la>
NEXT_PUBLIC_SITE_URL=https://www.jamesroman.la

# Internal operation secrets. Generate unique random values per environment.
HEALTHCHECK_SECRET=
NOTIFICATION_SECRET=
MIGRATION_SECRET=
SEED_SECRET=
SEED_USERS_SECRET=
SEED_USERS_DEFAULT_PASSWORD=
FIX_TRIGGER_SECRET=
STORAGE_SETUP_SECRET=
TEST_USERS_SETUP_SECRET=
AUTH_SETUP_SECRET=
AUTH_SETUP_ADMIN_PASSWORD=
AUTH_SETUP_CLIENT_PASSWORD=
